(defcfg
  input  (device-file "/dev/input/k100air")
  output (uinput-sink "kmonadk100air")
  fallthrough true
  allow-cmd false)

(defsrc
  esc capslock h j k l lsft
)

(defalias
  capsaction (tap-next esc (layer-toggle arrows))
  lshift (around lsft (layer-toggle shift))
)

(deflayer base
  esc @capsaction h j k l @lshift
)

(deflayer arrows
  _ _ left down up right _
)

(deflayer shift
  _ capslock _ _ _ _ _
)
